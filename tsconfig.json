{
    "include": [
        // other files...
        "./typed-router.d.ts",
        "./components.d.ts",
        "./auto-imports.d.ts",
        "declarations.d.ts"
    ],
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "isolatedModules": true,
        "baseUrl": ".",
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "Bundler",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": [
            "unplugin-vue-router/client"
        ],
        "jsx": "preserve",
        "paths": {
            "@assets/*": [
                "src/assets/*"
            ],
            "@components/*": [
                "src/pages/components/*"
            ],
            "@lib/*": [
                "src/lib/*"
            ],
            "@logs/*": [
                "src/logs/*"
            ],
            "@pages/*": [
                "src/pages/*"
            ],
            "@script/*": [
                "src/script/*"
            ],
            "@service/*": [
                "src/service/*"
            ],
            "@stores/*": [
                "src/stores/*"
            ],
            "@/*": [
                "src/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@css/*": [
                "src/assets/css/*"
            ],
            "@img/*": [
                "src/assets/img/*"
            ],
            "@theming/*": [
                "src/assets/theming/*"
            ],
            "@builds/*": [
                "src/pages/builds/*"
            ],
            "@champions/*": [
                "src/pages/champions/*"
            ],
            "@items/*": [
                "src/pages/items/*"
            ],
            "@runes/*": [
                "src/pages/runes/*"
            ],
            "@data/*": [
                "src/data/*"
            ]
        }
    }
}