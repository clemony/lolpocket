{
    "include": [
        "./typed-router.d.ts"
    ],
    "compilerOptions": {
        "baseUrl": ".",
        "types": [
            "unplugin-vue-router/client"
        ],
        "paths": {
            "@assets/*": [
                "src/assets/*"
            ],
            "@blank/*": [
                "src/blank/*"
            ],
            "@data/*": [
                "src/data/*"
            ],
            "@lib/*": [
                "src/lib/*"
            ],
            "@logs/*": [
                "src/logs/*"
            ],
            "@pages/*": [
                "src/pages/*"
            ],
            "@script/*": [
                "src/script/*"
            ],
            "@service/*": [
                "src/service/*"
            ],
            "@stores/*": [
                "src/stores/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@/*": [
                "src/*"
            ]
        }
    }
}