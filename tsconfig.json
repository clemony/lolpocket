{
    "include": [
        "src/**/*",
        "auto-imports.d.ts",
        "components.d.ts",
        "types.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
    "compilerOptions": {
        "baseUrl": ".",
        "allowSyntheticDefaultImports": true,
        "allowJs": true,
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "module": "ESNext",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "lib": [
            "es2020",
            "dom"
        ],
        "paths": {
            "@assets/*": [
                "src/assets/*"
            ],
            "@/assets/*": [
                "src/assets/*"
            ],
            "@data/*": [
                "src/data/*"
            ],
            "@lib/*": [
                "src/lib/*"
            ],
            "@logs/*": [
                "src/logs/*"
            ],
            "@/pages/*": [
                "src/pages/*"
            ],
            "@pages/*": [
                "src/pages/*"
            ],
            "@script/*": [
                "src/script/*"
            ],
            "@stores/*": [
                "src/stores/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@/components/*": [
                "src/components/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@/*": [
                "src/*"
            ],
        }
    }
}