{
    "include": [
        // other files...
        "./typed-router.d.ts",
        "./components.d.ts",
        "./auto-imports.d.ts",
        "index.d.ts",
        "./src/logs/vite-aliases.json"
    ],
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "isolatedModules": true,
        "baseUrl": ".",
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "Bundler",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": [
            "unplugin-vue-router/client"
        ],
        "jsx": "preserve",
        "paths": {
            "@assets/*": [
                "src/assets/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@data/*": [
                "src/data/*"
            ],
            "@lib/*": [
                "src/utils/*"
            ],
            "@logs/*": [
                "src/logs/*"
            ],
            "@pages/*": [
                "src/pages/*"
            ],
            "@script/*": [
                "src/script/*"
            ],
            "@service/*": [
                "src/service/*"
            ],
            "@stores/*": [
                "src/stores/*"
            ],
            "@ui/*": [
                "src/components/ui/*"
            ],
            "@modules/*": [
                "src/pages/modules/*"
            ],
            "@/*": [
                "src/*"
            ],
            "@page-build/*": [
                "src/page-build/*"
            ],
            "@cn/*": [
                "src/components/cn/*"
            ],
            "@aura/*": [
                "src/assets/aura/*"
            ],
            "@primevue/*": [
                "src/assets/primevue/*"
            ],
            "@splitterpanel/*": [
                "src/assets/aura/splitterpanel/*"
            ]
        }
    }
}