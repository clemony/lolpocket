{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "package": {
    "productName": "lolpocket",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "window": {
        "setResizable": true,
        "setMaximizable": true,
        "setMinimizable": true,
        "setClosable": true,
        "setTitle": true,
        "maximize": true,
        "unmaximize": true,
        "minimize": true,
        "unminimize": true,
        "show": true,
        "hide": true,
        "close": true,
        "startDragging": true
      },
      "shell": {
        "all": false, 
        "execute": false, 
        "sidecar": false, 
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["deb", "msi", "nsis", "dmg"],
      "icon": [
        "./icons/32x32.png",
        "./icons/64x64.png",
        "./icons/128x128@2x.png",
        "./icons/128x128@2x.png"
      ],
      "identifier": "com.example.app",
      "resources": []
    },
    "macOSPrivateApi": true,  
    "windows": [
      {
        "title": "lolpocket",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ]
  
  }
}
